      <aliases enabled='yes' />
      <column caption='customer churn' datatype='integer' default-format='p0.0%' name='[Calculation_0477206789320704]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Churn] = &quot;Yes&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='tenure custopmer' datatype='string' name='[Calculation_0477206795177985]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [tenure] &lt;= 12 THEN &quot;0–12 Months&quot;&#13;&#10;ELSEIF [tenure] &lt;= 24 THEN &quot;13–24 Months&quot;&#13;&#10;ELSEIF [tenure] &lt;= 48 THEN &quot;25–48 Months&quot;&#13;&#10;ELSE &quot;49+ Months&quot;&#13;&#10;END' />
      </column>
      <column caption='Senior Citizen Group' datatype='string' name='[Calculation_0477206803955714]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [SeniorCitizen] = 1 THEN&#13;&#10;    &quot;Senior Citizen&quot;&#13;&#10;ELSE&#13;&#10;    &quot;Non-Senior&quot;&#13;&#10;END' />
      </column>
